# ── Postgres (read by docker-compose.yml via ${VAR} substitution) ─────────────
# Change POSTGRES_PASSWORD in production. Compose wires the same values into
# postgres, web, worker, and migrate — no edits to docker-compose.yml needed.
POSTGRES_USER=gridnull
POSTGRES_PASSWORD=gridnull
POSTGRES_DB=gridnull

# Host dev only (npm run dev / npm run db:migrate on the host): port 5433.
# Keep the password in sync with POSTGRES_PASSWORD above.
DATABASE_URL=postgresql://gridnull:gridnull@localhost:5433/gridnull

# ── Redis / BullMQ ────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Ollama (Docker via npm run docker:up) ─────────────────────────────────────
OLLAMA_HOST=http://localhost:11434
OLLAMA_CHAT_MODEL=llama3.2:3b
OLLAMA_EMBED_MODEL=nomic-embed-text

# ── Worker ────────────────────────────────────────────────────────────────────
WORKER_CONCURRENCY=2
LLM_WORKER_CONCURRENCY=1

# ── Security (Phase 3a — production) ───────────────────────────────────────────
# Optional locally; required in production to encrypt VCS PATs at rest.
# Generate: openssl rand -base64 32
TOKEN_ENCRYPTION_KEY=

# API rate limiting (Redis-backed) — see docs/security.md#rate-limiting
# Enabled by default when NODE_ENV=production; set true locally to test throttling.
RATE_LIMIT_ENABLED=
# Window length in seconds; all *_MAX limits apply per window.
RATE_LIMIT_WINDOW_SECONDS=60
# Max authenticated API requests per user per window (all /api/* routes).
RATE_LIMIT_MAX_REQUESTS=120
# Additional per-user caps for expensive routes (checked alongside global limit):
RATE_LIMIT_SYNC_MAX=10
RATE_LIMIT_ANALYZE_MAX=5
RATE_LIMIT_APPLY_MAX=20
RATE_LIMIT_ADMIN_MAX=30
# OAuth login routes (/api/auth/*) — per client IP per window:
RATE_LIMIT_AUTH_MAX=20
# Use X-Forwarded-For / X-Real-IP when behind a reverse proxy (recommended in prod).
RATE_LIMIT_TRUST_PROXY=true

# ── Auto-sync (Phase 3b) ───────────────────────────────────────────────────────
# Worker registers a repeatable BullMQ tick when enabled.
AUTO_SYNC_SCHEDULER_ENABLED=false
AUTO_SYNC_TICK_MINUTES=15

# ── Web ───────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── Auth (disabled by default for local dev) ──────────────────────────────────
# Production: see docs/security.md — set AUTH_DISABLED=false, strong AUTH_SECRET, HTTPS
AUTH_DISABLED=true
AUTH_SECRET=
AUTH_URL=http://localhost:3000

# Deployment profile: on-prem (gitlab + shared) or hosted (github + per_user)
AUTH_PROVIDERS=github,gitlab
AUTH_DATA_SCOPE=shared

# On-prem gate (optional; enforced when set)
ALLOWED_EMAIL_DOMAINS=
ALLOWED_EMAILS=

# Comma-separated emails that receive ADMIN role on sign-in
ADMIN_EMAILS=

# GitHub OAuth (login — separate from sync PAT)
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=

# GitLab OAuth (login — set issuer for self-hosted instances)
AUTH_GITLAB_ID=
AUTH_GITLAB_SECRET=
AUTH_GITLAB_ISSUER=https://gitlab.com
