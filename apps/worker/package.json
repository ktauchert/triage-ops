{
  "name": "@triage-ops/worker",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "dotenv -e ../../.env -- tsx watch src/index.ts",
    "build": "esbuild src/index.ts --bundle --platform=node --target=node20 --outfile=dist/index.js --format=esm --external:@triage-ops/db --external:bullmq --external:ioredis",
    "start": "node dist/index.js",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "seed:gitlab": "dotenv -e ../../.env -- tsx scripts/seed-gitlab.ts"
  },
  "dependencies": {
    "@triage-ops/db": "*",
    "@triage-ops/shared-types": "*",
    "bullmq": "^5.56.0",
    "ioredis": "^5.6.1",
    "msw": "^2.14.6"
  },
  "devDependencies": {
    "@types/node": "^20",
    "dotenv-cli": "^8.0.0",
    "esbuild": "^0.25.12",
    "tsx": "^4",
    "typescript": "^5",
    "vitest": "^3.2.6"
  }
}
