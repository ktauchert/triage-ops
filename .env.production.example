# Gridnull production environment template
# Copy to .env on the install host. Replace every <placeholder>.
# See docs/security.md and docs/intranet-rollout.md.

# ── Container images (product install) ─────────────────────────────────────────
GRIDNULL_REGISTRY=ghcr.io/ktauchert
GRIDNULL_VERSION=1.0.0

# ── Postgres ───────────────────────────────────────────────────────────────────
POSTGRES_USER=gridnull
POSTGRES_PASSWORD=<strong-password>
POSTGRES_DB=gridnull
DATABASE_URL=postgresql://gridnull:<strong-password>@postgres:5432/gridnull

# ── Redis / BullMQ ─────────────────────────────────────────────────────────────
REDIS_PASSWORD=<strong-password>
REDIS_URL=redis://:<strong-password>@redis:6379

# ── Ollama (internal only — pull models before first analysis) ─────────────────
OLLAMA_HOST=http://ollama:11434
OLLAMA_CHAT_MODEL=llama3.2:3b
OLLAMA_EMBED_MODEL=nomic-embed-text

# ── Worker ─────────────────────────────────────────────────────────────────────
WORKER_CONCURRENCY=2
LLM_WORKER_CONCURRENCY=1
WRITEBACK_WORKER_CONCURRENCY=2
AUTO_SYNC_SCHEDULER_ENABLED=true
AUTO_SYNC_TICK_MINUTES=15

# ── Web ────────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=production

# ── Auth (required) ────────────────────────────────────────────────────────────
AUTH_DISABLED=false
AUTH_SECRET=<openssl rand -base64 32>
AUTH_URL=https://triageops.company.internal
AUTH_PROVIDERS=github,gitlab
AUTH_DATA_SCOPE=shared

# Closed registration: set at least one allowlist (recommended)
ALLOWED_EMAIL_DOMAINS=company.com
ALLOWED_EMAILS=

# Optional automation fallback for admin role on sign-in
ADMIN_EMAILS=

AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=
AUTH_GITLAB_ID=
AUTH_GITLAB_SECRET=
AUTH_GITLAB_ISSUER=https://gitlab.com

# ── Security ───────────────────────────────────────────────────────────────────
# Required — encrypt VCS PATs at rest
TOKEN_ENCRYPTION_KEY=<openssl rand -base64 32>

# API rate limiting — see docs/security.md#environment-variables
# Enabled by default in production (NODE_ENV=production).
RATE_LIMIT_ENABLED=true
# Window length in seconds; all *_MAX limits apply per window.
RATE_LIMIT_WINDOW_SECONDS=60
# Max authenticated API requests per user per window (all /api/* routes).
RATE_LIMIT_MAX_REQUESTS=120
# Additional per-user caps for expensive routes (checked alongside global limit):
RATE_LIMIT_SYNC_MAX=10
RATE_LIMIT_ANALYZE_MAX=5
RATE_LIMIT_APPLY_MAX=20
RATE_LIMIT_ADMIN_MAX=30
# OAuth login routes (/api/auth/*) — per client IP per window:
RATE_LIMIT_AUTH_MAX=20
# Use X-Forwarded-For / X-Real-IP when behind a reverse proxy.
RATE_LIMIT_TRUST_PROXY=true

# Never set in production unless controlled CI:
# ALLOW_AUTH_DISABLED=true
