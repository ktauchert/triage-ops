{
  "name": "triage-ops",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev -w @triage-ops/web",
    "dev:worker": "npm run dev -w @triage-ops/worker",
    "build": "npm run build --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "test:e2e": "npm run test -w @triage-ops/e2e",
    "db:generate": "npm run db:generate -w @triage-ops/db",
    "db:migrate": "npm run db:migrate -w @triage-ops/db",
    "db:migrate:deploy": "npm run db:migrate:deploy -w @triage-ops/db",
    "db:seed": "npm run db:seed -w @triage-ops/db",
    "gitlab:seed": "npm run seed:gitlab -w @triage-ops/worker",
    "docker:up": "docker compose up -d postgres redis ollama",
    "docker:up:all": "docker compose --profile production up -d",
    "docker:down": "docker compose down",
    "docker:migrate": "docker compose --profile migrate run --rm migrate"
  },
  "engines": {
    "node": ">=20"
  }
}
