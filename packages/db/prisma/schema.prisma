generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// Authenticated user (Auth.js).
model User {
  id            String          @id @default(cuid())
  name          String?
  email         String?         @unique
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]
  connections   VcsConnection[]

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

/// VCS credentials (GitLab instance or GitHub account).
model VcsConnection {
  id          String      @id(map: "gitlab_connections_pkey") @default(cuid())
  name        String
  provider    VcsProvider @default(GITLAB)
  baseUrl     String
  accessToken String
  isFavorite  Boolean     @default(false)
  userId      String?
  user        User?       @relation(fields: [userId], references: [id], onDelete: SetNull)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  projects    Project[]

  @@index([userId])
  @@map("vcs_connections")
}

/// A registered repository/project for triage sync.
model Project {
  id                  String        @id @default(cuid())
  externalProjectId   Int?
  pathWithNamespace   String
  name                String
  isFavorite          Boolean       @default(false)
  ghostThresholdDays  Int           @default(30)
  zombieThresholdDays Int           @default(14)
  lastSyncedAt        DateTime?
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt
  connectionId        String
  connection          VcsConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)
  issues              Issue[]
  milestones          Milestone[]
  labels              Label[]
  syncRuns            SyncRun[]
  issueSuggestions    IssueSuggestion[]
  llmAnalysisRuns     LlmAnalysisRun[]

  @@unique([connectionId, pathWithNamespace])
  @@index([connectionId])
  @@map("projects")
}

model Milestone {
  id                String         @id @default(cuid())
  gitlabMilestoneId Int
  title             String
  description       String?
  state             MilestoneState
  dueDate           DateTime?
  startDate         DateTime?
  createdAt         DateTime
  updatedAt         DateTime
  projectId         String
  project           Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  issues            Issue[]

  @@unique([projectId, gitlabMilestoneId])
  @@index([projectId, state])
  @@map("milestones")
}

model Label {
  id        String       @id @default(cuid())
  name      String
  color     String?
  projectId String
  project   Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  issues    IssueLabel[]

  @@unique([projectId, name])
  @@map("labels")
}

model Issue {
  id               String     @id @default(cuid())
  gitlabIssueIid   Int
  gitlabIssueId    BigInt
  title            String
  description      String?
  state            IssueState
  authorUsername   String?
  assigneeUsername String?
  weight           Int?
  createdAt        DateTime
  updatedAt        DateTime
  closedAt         DateTime?
  lastActivityAt   DateTime?
  syncedAt         DateTime   @default(now())
  projectId        String
  project          Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  milestoneId      String?
  milestone        Milestone? @relation(fields: [milestoneId], references: [id], onDelete: SetNull)
  labels           IssueLabel[]
  suggestionsAsPrimary   IssueSuggestion[] @relation("SuggestionPrimaryIssue")
  suggestionsAsRelated   IssueSuggestion[] @relation("SuggestionRelatedIssue")

  @@unique([projectId, gitlabIssueIid])
  @@index([projectId, state])
  @@index([lastActivityAt])
  @@index([milestoneId])
  @@map("issues")
}

model IssueLabel {
  issueId String
  labelId String
  issue   Issue  @relation(fields: [issueId], references: [id], onDelete: Cascade)
  label   Label  @relation(fields: [labelId], references: [id], onDelete: Cascade)

  @@id([issueId, labelId])
  @@map("issue_labels")
}

/// Audit trail for background sync jobs per project.
model SyncRun {
  id           String     @id @default(cuid())
  status       SyncStatus @default(PENDING)
  startedAt    DateTime   @default(now())
  completedAt  DateTime?
  issuesSynced Int        @default(0)
  errorMessage String?
  projectId    String
  project      Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, startedAt])
  @@index([status])
  @@map("sync_runs")
}

/// LLM-generated triage suggestion awaiting human review.
model IssueSuggestion {
  id             String                @id @default(cuid())
  projectId      String
  type           IssueSuggestionType
  status         IssueSuggestionStatus @default(PENDING)
  issueId        String
  relatedIssueId String?
  suggestedText  String?               @db.Text
  confidence     Float?
  model          String?
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt
  reviewedAt     DateTime?
  appliedAt      DateTime?
  project        Project               @relation(fields: [projectId], references: [id], onDelete: Cascade)
  issue          Issue                 @relation("SuggestionPrimaryIssue", fields: [issueId], references: [id], onDelete: Cascade)
  relatedIssue   Issue?                @relation("SuggestionRelatedIssue", fields: [relatedIssueId], references: [id], onDelete: SetNull)

  @@index([projectId, status])
  @@index([issueId])
  @@map("issue_suggestions")
}

/// Audit trail for LLM analysis jobs per project.
model LlmAnalysisRun {
  id                 String     @id @default(cuid())
  projectId          String
  status             SyncStatus @default(PENDING)
  startedAt          DateTime   @default(now())
  completedAt        DateTime?
  suggestionsCreated Int        @default(0)
  totalSteps         Int        @default(0)
  completedSteps     Int        @default(0)
  progressLabel      String?
  errorMessage       String?
  project            Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, startedAt])
  @@index([status])
  @@map("llm_analysis_runs")
}

enum IssueSuggestionType {
  DUPLICATE
  DESCRIPTION
}

enum IssueSuggestionStatus {
  PENDING
  DISMISSED
  APPLIED
}

enum VcsProvider {
  GITLAB
  GITHUB
}

enum IssueState {
  OPEN
  CLOSED
}

enum MilestoneState {
  ACTIVE
  CLOSED
}

enum SyncStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
}
