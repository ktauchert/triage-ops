{
  "name": "@gridnull/db",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./assert-encryption-configured": {
      "types": "./src/assert-encryption-configured.ts",
      "import": "./dist/assert-encryption-configured.js",
      "default": "./dist/assert-encryption-configured.js"
    }
  },
  "scripts": {
    "build": "prisma generate && tsc",
    "lint": "tsc --noEmit",
    "db:generate": "prisma generate",
    "db:migrate": "dotenv -e ../../.env -- prisma migrate dev",
    "db:migrate:deploy": "dotenv -e ../../.env -- prisma migrate deploy",
    "db:push": "dotenv -e ../../.env -- prisma db push",
    "db:studio": "dotenv -e ../../.env -- prisma studio",
    "db:seed": "dotenv -e ../../.env -- tsx src/seed.ts",
    "test": "vitest run"
  },
  "dependencies": {
    "@prisma/client": "^6.19.3",
    "dotenv": "^16.6.1"
  },
  "devDependencies": {
    "dotenv-cli": "^8.0.0",
    "prisma": "^6.19.3",
    "tsx": "^4",
    "typescript": "^5",
    "vitest": "^3.2.6"
  },
  "prisma": {
    "seed": "tsx src/seed.ts"
  }
}
