# Gridnull production environment template
# Copy to .env on the install host. Replace every <placeholder>.
# Full hardening guide: https://github.com/ktauchert/gridnull/blob/main/docs/security.md

# ── Container images (pinned in docker-compose.prod.yml for this bundle) ───────
GRIDNULL_REGISTRY=ghcr.io/ktauchert
GRIDNULL_VERSION={{VERSION}}

# ── Postgres ───────────────────────────────────────────────────────────────────
POSTGRES_USER=triage_ops
POSTGRES_PASSWORD=<strong-password>
POSTGRES_DB=triage_ops
DATABASE_URL=postgresql://triage_ops:<strong-password>@postgres:5432/triage_ops

# ── Redis / BullMQ ─────────────────────────────────────────────────────────────
REDIS_PASSWORD=<strong-password>
REDIS_URL=redis://:<strong-password>@redis:6379

# ── Ollama (internal only — pull models before first analysis) ─────────────────
OLLAMA_HOST=http://ollama:11434
OLLAMA_CHAT_MODEL=llama3.2:3b
OLLAMA_EMBED_MODEL=nomic-embed-text

# ── Worker ─────────────────────────────────────────────────────────────────────
WORKER_CONCURRENCY=2
LLM_WORKER_CONCURRENCY=1
WRITEBACK_WORKER_CONCURRENCY=2
AUTO_SYNC_SCHEDULER_ENABLED=true
AUTO_SYNC_TICK_MINUTES=15

# ── Web ────────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=production

# ── Auth (required) ────────────────────────────────────────────────────────────
AUTH_DISABLED=false
AUTH_SECRET=<openssl rand -base64 32>
AUTH_URL=https://triageops.company.internal
AUTH_PROVIDERS=github,gitlab
AUTH_DATA_SCOPE=shared

# Closed registration: set at least one allowlist (recommended)
ALLOWED_EMAIL_DOMAINS=company.com
ALLOWED_EMAILS=

# Optional automation fallback for admin role on sign-in
ADMIN_EMAILS=

AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=
AUTH_GITLAB_ID=
AUTH_GITLAB_SECRET=
AUTH_GITLAB_ISSUER=https://gitlab.com

# ── Security ───────────────────────────────────────────────────────────────────
# Required — encrypt VCS PATs at rest
TOKEN_ENCRYPTION_KEY=<openssl rand -base64 32>

# API rate limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_MAX_REQUESTS=120
RATE_LIMIT_SYNC_MAX=10
RATE_LIMIT_ANALYZE_MAX=5
RATE_LIMIT_APPLY_MAX=20
RATE_LIMIT_ADMIN_MAX=30
RATE_LIMIT_AUTH_MAX=20
RATE_LIMIT_TRUST_PROXY=true

# Never set in production unless controlled CI:
# ALLOW_AUTH_DISABLED=true
